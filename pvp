UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if rebinding and activeRebindLabel then
        if input.UserInputType ~= Enum.UserInputType.Keyboard then
            return
        end

        local baseText = activeRebindLabel:GetAttribute("baseText") or "bind: "
        if input.KeyCode == Enum.KeyCode.Backspace then
            if activeRebindLabel == guiKeyLabel then guiBind = nil
            elseif activeRebindLabel == dashKeyLabel then dashBind = nil
            elseif activeRebindLabel == unbreakableKeyLabel then unbreakableBind = nil
            elseif activeRebindLabel == antiStunKeyLabel then antiStunBind = nil
            elseif activeRebindLabel == killAuraKeyLabel then killAuraBind = nil
            elseif activeRebindLabel == noClipKeyLabel then noClipBind = nil
            end
            activeRebindLabel.Text = baseText .. "unbound"
        else
            local newKey = input.KeyCode
            local keyName = newKey.Name

            local conflictWithOther = false
            if newKey == guiBind and activeRebindLabel ~= guiKeyLabel then conflictWithOther = true end
            if newKey == dashBind and activeRebindLabel ~= dashKeyLabel then conflictWithOther = true end
            if newKey == unbreakableBind and activeRebindLabel ~= unbreakableKeyLabel then conflictWithOther = true end
            if newKey == antiStunBind and activeRebindLabel ~= antiStunKeyLabel then conflictWithOther = true end
            if newKey == killAuraBind and activeRebindLabel ~= killAuraKeyLabel then conflictWithOther = true end
            if newKey == noClipBind and activeRebindLabel ~= noClipKeyLabel then conflictWithOther = true end

            if conflictWithOther then
                if activeRebindLabel == guiKeyLabel then guiBind = nil
                elseif activeRebindLabel == dashKeyLabel then dashBind = nil
                elseif activeRebindLabel == unbreakableKeyLabel then unbreakableBind = nil
                elseif activeRebindLabel == antiStunKeyLabel then antiStunBind = nil
                elseif activeRebindLabel == killAuraKeyLabel then killAuraBind = nil
                elseif activeRebindLabel == noClipKeyLabel then noClipBind = nil
                end
                activeRebindLabel.Text = baseText .. "unbound"
                rebinding = false
                activeRebindLabel = nil
                return
            end

            if activeRebindLabel == guiKeyLabel then guiBind = newKey
            elseif activeRebindLabel == dashKeyLabel then dashBind = newKey
            elseif activeRebindLabel == unbreakableKeyLabel then unbreakableBind = newKey
            elseif activeRebindLabel == antiStunKeyLabel then antiStunBind = newKey
            elseif activeRebindLabel == killAuraKeyLabel then killAuraBind = newKey
            elseif activeRebindLabel == noClipKeyLabel then noClipBind = newKey
            end
            activeRebindLabel.Text = baseText .. keyName
        end
        rebinding = false
        activeRebindLabel = nil
        return
    end

    if guiBind and input.KeyCode == guiBind then
        gui.Enabled = not gui.Enabled
    end
    if dashBind and input.KeyCode == dashBind then
        toggleDash()
    end
    if unbreakableBind and input.KeyCode == unbreakableBind then
        toggleUnbreakable()
    end
    if antiStunBind and input.KeyCode == antiStunBind then
        toggleAntiStun()
    end
    if killAuraBind and input.KeyCode == killAuraBind then
        toggleKillAura()
    end
    if noClipBind and input.KeyCode == noClipBind then
        toggleNoClip()
    end
end)

