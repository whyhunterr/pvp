local function toggleDash()
    dashEnabled = not dashEnabled
    if dashEnabled then
        dashToggle.Text = "DISABLE LONG DASH"
        dashToggle.TextColor3 = Color3.fromRGB(255, 100, 100)
        if dashConnection then task.cancel(dashConnection) end
        dashConnection = task.spawn(function()
            while dashEnabled do
                task.wait(0.1)
                local character = LocalPlayer.Character
                if character then
                    character:SetAttribute("DashLength", dashLength)
                    character:SetAttribute("DashLengthAir", dashLength)
                end
            end
        end)
    else
        dashToggle.Text = "ENABLE LONG DASH"
        dashToggle.TextColor3 = Color3.fromRGB(210, 210, 210)
        if dashConnection then 
            task.cancel(dashConnection) 
            dashConnection = nil 
        end
        local character = LocalPlayer.Character
        if character then
            character:SetAttribute("DashLength", 1)
            character:SetAttribute("DashLengthAir", 1)
        end
    end
end

local function applyUnbreakable()
    if unbreakableEnabled and LocalPlayer.Character then
        LocalPlayer.Character:SetAttribute("Unbreakable", true)
        LocalPlayer.Character:SetAttribute("UnbreakableAll", true)
    end
end

local function toggleUnbreakable()
    unbreakableEnabled = not unbreakableEnabled
    if unbreakableEnabled then
        unbreakableToggle.Text = "DISABLE UNBREAKABLE"
        unbreakableToggle.TextColor3 = Color3.fromRGB(255, 100, 100)
        applyUnbreakable()
        if not unbreakableConnection then
            unbreakableConnection = LocalPlayer.CharacterAdded:Connect(applyUnbreakable)
        end
    else
        unbreakableToggle.Text = "ENABLE UNBREAKABLE"
        unbreakableToggle.TextColor3 = Color3.fromRGB(210, 210, 210)
        if LocalPlayer.Character then
            LocalPlayer.Character:SetAttribute("Unbreakable", false)
            LocalPlayer.Character:SetAttribute("UnbreakableAll", false)
        end
    end
end

local function toggleAntiStun()
