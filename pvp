local function createKeybindLabel(yPos, displayName)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -22, 0, 18)
    lbl.Position = UDim2.new(0, 11, 0, yPos)
    lbl.BackgroundTransparency = 1
    lbl.TextColor3 = Color3.fromRGB(160, 160, 160)
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = 11
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = content

    local baseText = displayName .. " bind: "
    lbl.Text = baseText .. "unbound"
    lbl:SetAttribute("baseText", baseText)

    lbl.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            rebinding = true
            activeRebindLabel = lbl
            lbl.Text = baseText .. "press any key..."
        end
    end)
    return lbl
end

