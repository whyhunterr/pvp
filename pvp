-- Keybind
local keybindLabel = Instance.new("TextLabel")
keybindLabel.Size = UDim2.new(1, -22, 0, 40)
keybindLabel.Position = UDim2.new(0, 11, 0, 195)
keybindLabel.BackgroundTransparency = 1
keybindLabel.Text = "toggle gui visibility bind: unbound"
keybindLabel.TextColor3 = Color3.fromRGB(160, 160, 160)
keybindLabel.Font = Enum.Font.Gotham
keybindLabel.TextSize = 12
keybindLabel.TextWrapped = true
keybindLabel.Parent = content

local currentBind = nil
local rebinding = false
local unbreakableEnabled = false

keybindLabel.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        rebinding = true
        keybindLabel.Text = "toggle gui visibility bind: press any key..."
        task.delay(0.1, function() rebinding = true end) -- small delay
    end
end)

UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end

    if rebinding then
        if input.KeyCode == Enum.KeyCode.Backspace then
            currentBind = nil
            keybindLabel.Text = "toggle gui visibility bind: unbound"
        else
            currentBind = input.KeyCode
            local keyName = tostring(input.KeyCode):gsub("Enum.KeyCode.", "")
            keybindLabel.Text = "toggle gui visibility bind: " .. keyName
        end
        rebinding = false
        return
    end

    if currentBind and input.KeyCode == currentBind then
        gui.Enabled = not gui.Enabled
    end
end)

-- Dash logic
local enabled = false
local dashLength = 85
local dashConnection = nil

dashToggle.MouseButton1Click:Connect(function()
    enabled = not enabled
    if enabled then
        dashToggle.Text = "DISABLE LONG DASH"
        dashToggle.TextColor3 = Color3.fromRGB(255, 100, 100)
        dashConnection = task.spawn(function()
            while enabled do
                task.wait(0.15)
                local character = LocalPlayer.Character
                if character then
                    character:SetAttribute("DashLength", dashLength)
                    character:SetAttribute("DashLengthAir", dashLength)
                end
            end
        end)
    else
        dashToggle.Text = "ENABLE LONG DASH"
        dashToggle.TextColor3 = Color3.fromRGB(210, 210, 210)
        if dashConnection then task.cancel(dashConnection) end
    end
end)

strengthBox.FocusLost:Connect(function()
    local num = tonumber(strengthBox.Text)
    if num then dashLength = math.clamp(num, 1, 500) end
    strengthBox.Text = tostring(dashLength)
end)

-- Unbreakable
unbreakableToggle.MouseButton1Click:Connect(function()
    unbreakableEnabled = not unbreakableEnabled
    if unbreakableEnabled then
        unbreakableToggle.Text = "DISABLE UNBREAKABLE"
        unbreakableToggle.TextColor3 = Color3.fromRGB(255, 100, 100)
        if LocalPlayer.Character then
            LocalPlayer.Character:SetAttribute("Unbreakable", true)
            LocalPlayer.Character:SetAttribute("UnbreakableAll", true)
        end
    else
        unbreakableToggle.Text = "ENABLE UNBREAKABLE"
        unbreakableToggle.TextColor3 = Color3.fromRGB(210, 210, 210)
        if LocalPlayer.Character then
            LocalPlayer.Character:SetAttribute("Unbreakable", false)
            LocalPlayer.Character:SetAttribute("UnbreakableAll", false)
        end
    end
end)

-- Dragging, Minimize, Close
local dragging = false
local dragStart, startPos
bar.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = i.Position
        startPos = frame.Position
    end
end)

UserInputService.InputChanged:Connect(function(i)
    if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = i.Position - dragStart
        frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

UserInputService.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
end)

local minimized = false
local originalSize = frame.Size
minimizeBtn.MouseButton1Click:Connect(function()
    minimized = not minimized
    if minimized then
        frame.Size = UDim2.new(0, 280, 0, 32)
        content.Visible = false
        minimizeBtn.Text = "+"
    else
        frame.Size = originalSize
        content.Visible = true
        minimizeBtn.Text = "−"
    end
end)

closeBtn.MouseButton1Click:Connect(function()
    if dashConnection then task.cancel(dashConnection) end
    gui:Destroy()
end)

print("hunter's pvp script loaded")
